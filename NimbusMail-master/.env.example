# ── Upstash Redis (used by BullMQ queue + worker + rate limiter) ──
REDIS_URL=redis://default:password@host:port

# ── Neon Postgres (used by src/db/index.js) ──
DATABASE_URL=postgresql://user:password@host:5432/email_service

# ── Email provider: SendGrid ──
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM=noreply@yourdomain.com

# ── Email provider: Mailgun ──
MAILGUN_API_KEY=key-xxxxx
MAILGUN_DOMAIN=sandbox.mailgun.org
MAILGUN_FROM=noreply@yourdomain.com

# ── Email provider: SMTP (Nodemailer fallback) ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-user
SMTP_PASS=your-pass
SMTP_FROM=noreply@yourdomain.com
SMTP_SECURE=false

# ── Anthropic AI (email content personalisation) ──
ANTHROPIC_API_KEY=sk-ant-xxxxx
AI_PERSONALISATION_ENABLED=true

# ── Runtime ──
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
