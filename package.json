{
  "name": "email-sender",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "ts-node src/db/migrate.ts",
    "migrate:build": "node dist/db/migrate.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "loadtest": "k6 run tests/load/campaign.js",
    "dashboard": "cd dashboard && npm run dev",
    "frontend": "cd Email-frontned-main && npm install && npm run dev -- --port 5174"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@sendgrid/eventwebhook": "^8.0.0",
    "@sendgrid/mail": "^8.1.6",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "ioredis": "^5.11.1",
    "mailgun.js": "^13.2.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  }
}
